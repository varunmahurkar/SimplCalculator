---
import Icon from "../ui/Icon.astro";

const examples = [
  "I want to buy a ₹50 lakh house",
  "I earn ₹80k per month",
  "I want to invest ₹10k monthly",
  "What's 18% GST on ₹2,400?",
];
---

<div
  data-assistant-root
  hidden
  class="fixed inset-0 z-50 flex justify-end bg-ink/30 backdrop-blur-sm"
  role="dialog"
  aria-modal="true"
  aria-label="AI calculation assistant"
>
  <aside
    data-assistant-dialog
    class="flex h-full w-full max-w-md flex-col bg-canvas shadow-e5"
  >
    <header class="flex items-center justify-between border-b border-hairline px-5 py-4">
      <div class="flex items-center gap-2">
        <span class="flex h-8 w-8 items-center justify-center rounded-md bg-primary text-on-primary">
          <Icon path="M12 3l1.9 5.1L19 10l-5.1 1.9L12 17l-1.9-5.1L5 10l5.1-1.9z" size={16} />
        </span>
        <div>
          <p class="text-body-sm-strong font-medium text-ink">Calculation Assistant</p>
          <p class="text-caption text-mute">Describe your situation</p>
        </div>
      </div>
      <button
        data-assistant-close
        class="flex h-8 w-8 items-center justify-center rounded-md text-mute hover:bg-canvas-soft-2 hover:text-ink"
        aria-label="Close assistant"
      >
        <Icon path="M6 6l12 12M18 6L6 18" size={18} />
      </button>
    </header>

    <form data-assistant-form class="border-b border-hairline px-5 py-4">
      <label for="assistant-input" class="sr-only">Your situation</label>
      <div class="flex items-center gap-2 rounded-md border border-hairline bg-canvas px-3 focus-within:border-hairline-strong">
        <input
          id="assistant-input"
          data-assistant-input
          type="text"
          placeholder="e.g. I want to buy a house…"
          class="h-11 w-full bg-transparent text-body-sm text-ink outline-none placeholder:text-mute"
          autocomplete="off"
        />
        <button type="submit" class="flex h-8 w-8 items-center justify-center rounded-md bg-primary text-on-primary hover:opacity-90" aria-label="Ask">
          <Icon path="M5 12h14M13 6l6 6-6 6" size={16} />
        </button>
      </div>
      <div class="mt-3 flex flex-wrap gap-1.5">
        {
          examples.map((ex) => (
            <button
              type="button"
              data-assistant-example={ex}
              class="rounded-pill border border-hairline px-2.5 py-1 text-caption text-body hover:bg-canvas-soft-2 hover:text-ink"
            >
              {ex}
            </button>
          ))
        }
      </div>
    </form>

    <div class="flex-1 overflow-y-auto px-5 py-4">
      <div data-assistant-output>
        <p class="text-body-sm text-mute">
          Tell me what you're trying to figure out and I'll point you to the right
          calculators — and a workflow to chain them together.
        </p>
      </div>
    </div>
  </aside>
</div>

<script>
  import { initAssistantPanel } from "../../islands/assistant-panel";
  initAssistantPanel();
</script>
