---
import Brand from "./Brand.astro";
import { categories } from "../../data/categories";
import { popular } from "../../lib/calculators/registry";

const cols = categories.slice(0, 4);
const year = 2026;
---

<footer class="border-t border-hairline bg-canvas">
  <div class="mx-auto max-w-[1400px] px-4 py-16 md:px-6">
    <div class="grid gap-10 md:grid-cols-[1.4fr_repeat(3,1fr)]">
      <div>
        <Brand />
        <p class="mt-3 max-w-xs text-body-sm text-body">
          Calculators that explain results. Calculate, visualize, understand,
          and decide — with AI on your side.
        </p>
      </div>

      <div>
        <p class="mb-3 font-mono text-caption uppercase tracking-wide text-mute">Popular</p>
        <ul class="space-y-2">
          {
            popular.slice(0, 5).map((c) => (
              <li>
                <a
                  href={`/calculators/${c.category}/${c.slug}`}
                  class="text-body-sm text-body transition-colors hover:text-ink"
                >
                  {c.title}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <div>
        <p class="mb-3 font-mono text-caption uppercase tracking-wide text-mute">Categories</p>
        <ul class="space-y-2">
          {
            cols.map((c) => (
              <li>
                <a
                  href={`/categories/${c.slug}`}
                  class="text-body-sm text-body transition-colors hover:text-ink"
                >
                  {c.name}
                </a>
              </li>
            ))
          }
          <li>
            <a href="/calculators" class="text-body-sm text-body transition-colors hover:text-ink">All calculators</a>
          </li>
        </ul>
      </div>

      <div>
        <p class="mb-3 font-mono text-caption uppercase tracking-wide text-mute">Product</p>
        <ul class="space-y-2">
          <li><a href="/" class="text-body-sm text-body transition-colors hover:text-ink">Home</a></li>
          <li><button data-assistant-open class="text-body-sm text-body transition-colors hover:text-ink">AI Assistant</button></li>
          <li><button data-search-open class="text-body-sm text-body transition-colors hover:text-ink">Search</button></li>
        </ul>
      </div>
    </div>

    <div class="mt-12 flex flex-col items-start justify-between gap-3 border-t border-hairline pt-6 sm:flex-row sm:items-center">
      <p class="text-caption text-mute">© {year} Simpl Calculator. All results are estimates.</p>
      <p class="font-mono text-caption text-mute">Built with Astro · Tailwind · AI</p>
    </div>
  </div>
</footer>
