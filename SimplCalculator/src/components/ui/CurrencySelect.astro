---
import { CURRENCIES, DEFAULT_CURRENCY } from "../../lib/currency";

export interface Props {
  class?: string;
  compact?: boolean;
}
const { class: cls = "", compact = false } = Astro.props;
---

<label class={`relative inline-flex items-center ${cls}`}>
  <span class="sr-only">Currency</span>
  <select
    data-currency-select
    class="h-9 cursor-pointer appearance-none rounded-md border border-hairline bg-canvas pl-3 pr-7 text-body-sm text-ink outline-none hover:bg-canvas-soft-2 focus-visible:ring-2 focus-visible:ring-link"
  >
    {
      CURRENCIES.map((c) => (
        <option value={c.code} selected={c.code === DEFAULT_CURRENCY}>
          {compact ? `${c.symbol} ${c.code}` : `${c.symbol} ${c.code} — ${c.label}`}
        </option>
      ))
    }
  </select>
  <svg
    class="pointer-events-none absolute right-2 text-mute"
    width="14"
    height="14"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
  >
    <path d="M6 9l6 6 6-6"></path>
  </svg>
</label>
