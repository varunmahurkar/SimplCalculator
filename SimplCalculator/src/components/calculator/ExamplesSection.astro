---
export interface Props {
  examples: { scenario: string; detail: string }[];
}
const { examples } = Astro.props;
if (!examples.length) return null;
---

<section id="examples" class="scroll-mt-20">
  <h2 class="text-display-sm text-ink">Examples</h2>
  <div class="mt-4 grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
    {
      examples.map((ex, i) => (
        <div class="rounded-lg border border-hairline bg-canvas p-5 shadow-e2">
          <span class="font-mono text-caption text-mute">Example {i + 1}</span>
          <p class="mt-1 text-body-sm-strong font-medium text-ink">{ex.scenario}</p>
          <p class="mt-1 text-body-sm text-body">{ex.detail}</p>
        </div>
      ))
    }
  </div>
</section>
