---
import type { CalculatorDefinition } from "../../types/calculator";
import { defaultInputs } from "../../types/calculator";
import CalculatorForm from "./CalculatorForm.astro";
import Icon from "../ui/Icon.astro";
import CurrencySelect from "../ui/CurrencySelect.astro";
import { metricsGridHTML, chartContainersHTML } from "../../lib/render/result-html";
import { setActiveCurrencyCode } from "../../lib/currency";

export interface Props {
  def: CalculatorDefinition<any>;
}
const { def } = Astro.props;

// Currency for the SEO snapshot: locale-bound → its jurisdiction; else default.
setActiveCurrencyCode(def.localeBound?.currency ?? "USD");

// Server-rendered snapshot from defaults — meaningful without JS, good for SEO.
let initialResult;
try {
  initialResult = def.compute(def.schema.parse(defaultInputs(def)));
} catch {
  initialResult = { metrics: [], charts: [], summary: {} };
}
const hasCharts = initialResult.charts.length > 0;
const hasScenarios = (def.scenarios?.length ?? 0) > 1;
// Show the currency switcher only for money calculators that aren't locale-bound.
const usesCurrency = def.fields.some((f) => f.type === "currency");
const showCurrency = usesCurrency && !def.localeBound;
---

<section data-calc-app={def.slug} class="mx-auto max-w-[1400px] px-4 md:px-6">
  <!-- Toolbar -->
  <div class="mb-6 flex items-center justify-end gap-2">
    {showCurrency && <CurrencySelect compact class="mr-auto" />}
    {
      def.localeBound && (
        <span class="mr-auto inline-flex items-center gap-1.5 rounded-md border border-hairline bg-canvas-soft px-3 py-1.5 text-body-sm text-body">
          {def.localeBound.jurisdiction} · {def.localeBound.currency}
        </span>
      )
    }
    <button
      data-fav-toggle
      hidden
      aria-pressed="false"
      class="inline-flex h-9 items-center gap-1.5 rounded-md border border-hairline bg-canvas px-3 text-body-sm text-ink hover:bg-canvas-soft-2"
    >
      <Icon path="M12 17.3l-6.18 3.7 1.64-7.03L2 9.24l7.19-.61L12 2l2.81 6.63 7.19.61-5.46 4.73 1.64 7.03z" size={15} />
      Save
    </button>
    <button
      data-save-history
      hidden
      class="inline-flex h-9 items-center gap-1.5 rounded-md border border-hairline bg-canvas px-3 text-body-sm text-ink hover:bg-canvas-soft-2"
    >
      <Icon path="M19 21H5a2 2 0 01-2-2V5a2 2 0 012-2h11l5 5v11a2 2 0 01-2 2zM17 21v-8H7v8M7 3v5h8" size={15} />
      Save result
    </button>
    <button
      data-action="share"
      class="inline-flex h-9 items-center gap-1.5 rounded-md border border-hairline bg-canvas px-3 text-body-sm text-ink hover:bg-canvas-soft-2"
    >
      <Icon path="M4 12v7a1 1 0 001 1h14a1 1 0 001-1v-7M16 6l-4-4-4 4M12 2v13" size={15} />
      Share
    </button>
    <button
      data-action="print"
      class="inline-flex h-9 items-center gap-1.5 rounded-md border border-hairline bg-canvas px-3 text-body-sm text-ink hover:bg-canvas-soft-2"
    >
      <Icon path="M6 9V2h12v7M6 18H4a2 2 0 01-2-2v-3a2 2 0 012-2h16a2 2 0 012 2v3a2 2 0 01-2 2h-2M6 14h12v8H6z" size={15} />
      Report
    </button>
  </div>

  <div class="grid grid-cols-1 gap-6 lg:grid-cols-[minmax(320px,360px)_1fr]">
    <!-- Form -->
    <div class="min-w-0 lg:sticky lg:top-20 lg:self-start">
      <div class="rounded-lg border border-hairline bg-canvas p-6 shadow-e2">
        <h2 class="mb-4 text-display-sm text-ink">Inputs</h2>
        <CalculatorForm def={def} />
      </div>
    </div>

    <!-- Output (primary "tool" zone) -->
    <div class="grid min-w-0 gap-8">
      <div class="min-w-0">
        <h2 class="mb-3 text-display-sm text-ink">Results</h2>
        <div data-results set:html={metricsGridHTML(initialResult)} />
      </div>

      {
        hasCharts && (
          <div class="min-w-0">
            <h2 class="mb-3 text-display-sm text-ink">Visualizations</h2>
            <div
              data-charts
              class="grid min-w-0 gap-4 sm:grid-cols-2"
              set:html={chartContainersHTML(initialResult)}
            />
          </div>
        )
      }

      {
        hasScenarios && (
          <div class="min-w-0">
            <h2 class="mb-3 text-display-sm text-ink">Scenario comparison</h2>
            <div data-scenarios class="min-w-0" />
          </div>
        )
      }

      <div class="min-w-0">
        <div class="flex flex-wrap items-center justify-between gap-3">
          <h2 class="text-display-sm text-ink">Insights</h2>
          <button
            data-action="ai"
            class="inline-flex h-9 items-center gap-1.5 rounded-pill bg-primary px-4 text-body-sm font-medium text-on-primary hover:opacity-90"
          >
            <Icon path="M12 3l1.9 5.1L19 10l-5.1 1.9L12 17l-1.9-5.1L5 10l5.1-1.9z" size={15} />
            In-depth AI analysis
          </button>
        </div>

        <!-- Auto, free, local takeaways (always on) -->
        <div
          data-simple-insight
          class="mt-3 rounded-lg border border-hairline bg-canvas p-5"
        >
        </div>

        <!-- In-depth AI output (on demand) -->
        <div
          data-ai-output
          class="mt-3 rounded-lg border border-hairline bg-canvas-soft p-5 text-body-sm text-body"
        >
          Want the full picture? <span class="font-medium text-ink">In-depth AI analysis</span>
          adds risks, opportunities, and recommendations — and you can ask follow-up questions.
        </div>

        <!-- AI chat -->
        <div data-chat class="mt-3"></div>
      </div>
    </div>
  </div>

  <div
    data-toast
    hidden
    class="fixed bottom-6 left-1/2 z-50 -translate-x-1/2 rounded-md bg-primary px-4 py-2 text-body-sm text-on-primary shadow-e4"
    role="status"
  >
  </div>
</section>

<script>
  import { initCalculatorApp } from "../../islands/calculator-app";
  import { initCalcChat } from "../../islands/calc-chat";
  initCalculatorApp();
  initCalcChat();
</script>
