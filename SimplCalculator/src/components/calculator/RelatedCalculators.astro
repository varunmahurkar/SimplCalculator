---
import { getCalculator } from "../../lib/calculators/registry";
import Icon from "../ui/Icon.astro";

export interface Props {
  slugs: string[];
}
const { slugs } = Astro.props;
const related = slugs.map((s) => getCalculator(s)).filter(Boolean);
if (!related.length) return null;
---

<section class="scroll-mt-20">
  <h2 class="text-display-sm text-ink">Related calculators</h2>
  <div class="mt-4 grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
    {
      related.map((c) => (
        <a
          href={`/calculators/${c!.category}/${c!.slug}`}
          class="group flex items-start gap-3 rounded-lg border border-hairline bg-canvas p-5 shadow-e2 transition-shadow hover:shadow-e4"
        >
          <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-md bg-canvas-soft text-ink">
            <Icon path={c!.icon} size={18} />
          </span>
          <span>
            <span class="block text-body-sm-strong font-medium text-ink group-hover:text-link">
              {c!.title}
            </span>
            <span class="mt-0.5 block text-caption text-body">{c!.blurb}</span>
          </span>
        </a>
      ))
    }
  </div>
</section>
