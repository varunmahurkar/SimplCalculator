---
import type { CalculatorDefinition } from "../../types/calculator";
import Icon from "../ui/Icon.astro";

export interface Props {
  calc: CalculatorDefinition<any>;
}
const { calc } = Astro.props;
---

<a
  href={`/calculators/${calc.category}/${calc.slug}`}
  class="group flex h-full flex-col rounded-md border border-hairline bg-canvas p-5 shadow-e2 transition-shadow duration-150 hover:shadow-e4 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-link"
>
  <span class="flex h-10 w-10 items-center justify-center rounded-md bg-canvas-soft text-ink transition-colors group-hover:bg-primary group-hover:text-on-primary">
    <Icon path={calc.icon} size={20} />
  </span>
  <span class="mt-4 text-body-md-strong font-medium text-ink">{calc.title}</span>
  <span class="mt-1 flex-1 text-body-sm text-body">{calc.blurb}</span>
  <span class="mt-3 inline-flex items-center gap-1 text-body-sm text-link">
    Open
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform group-hover:translate-x-0.5" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"></path></svg>
  </span>
</a>
